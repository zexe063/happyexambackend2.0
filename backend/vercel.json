
{
    "version": 2,
    "builds": [
      {
        "src": "index.js",
        "use": "@vercel/node"
      }
    ],
    "routes": [
      {
        "src": "/class/(.*)",
        "dest": "index.js"
      },
      {
        "src": "/subject/(.*)",
        "dest": "index.js"
      },
      {
        "src": "/chapter/(.*)",
        "dest": "index.js"
      },
      {
        "src": "/level/(.*)",
        "dest": "index.js"
      },
      {
        "src": "/question/(.*)",
        "dest": "index.js"
      },
      {
        "src": "/(.*)",
        "dest": "index.js"
      }
    ]
   
  }